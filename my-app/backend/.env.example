# ===== CONFIGURAÇÃO DE AMBIENTE =====
# Copie este arquivo para .env e preencha com seus valores

# ===== SERVIDOR =====
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ===== DOMÍNIO / URL =====
# Para localhost
# DOMAIN=localhost
# DOMAIN_URL=http://localhost:3000

# Para domínio próprio (HTTPS recomendado)
DOMAIN=seu-dominio.com
DOMAIN_URL=https://seu-dominio.com
ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com,localhost

# ===== BASE DE DADOS =====
DB_PATH=./database/loja_sende.db
DB_BACKUP_PATH=./database/backups

# ===== SEGURANÇA - JWT =====
JWT_SECRET=MUDE_ISTO_PARA_UMA_CHAVE_MUITO_SEGURA_MINIMO_64_CARACTERES
JWT_EXPIRE=7d

# ===== SEGURANÇA - SESSION =====
SESSION_SECRET=OUTRA_CHAVE_SECRETA_MUITO_SEGURA_MINIMO_64_CARACTERES

# ===== CORS - Origens Permitidas =====
# Local: http://localhost:3000
# Produção: https://seu-dominio.com,https://www.seu-dominio.com
CORS_ORIGIN=https://seu-dominio.com,https://www.seu-dominio.com

# ===== COOKIES - Segurança em Produção =====
COOKIE_SECURE=true
COOKIE_SAMESITE=Strict

# ===== ADMIN =====
ADMIN_EMAIL=admin@loja.pt
ADMIN_PASSWORD=Admin@123

# ===== EMAIL (Para notificações) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app-gmail

# ===== PAGAMENTOS =====
STRIPE_SECRET_KEY=sk_live_sua_chave_stripe_secreta
STRIPE_PUBLIC_KEY=pk_live_sua_chave_publica_stripe
PAYPAL_CLIENT_ID=sua_paypal_client_id
PAYPAL_SECRET=sua_paypal_secret

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=30

# ===== LOGGING =====
LOG_LEVEL=info
LOG_PATH=./logs
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=Strict

# ===== HTTPS (Para Produção) =====
ENABLE_HTTPS=true
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# ===== BACKUP AUTOMÁTICO =====
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

# ===== MONITORING =====
SENTRY_DSN=https://seu-sentry-dsn-aqui

# ===== CACHE =====
CACHE_ENABLED=true
CACHE_TTL=3600
