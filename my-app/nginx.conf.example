# ============================================================
# Configuração Nginx - Loja Sende
# ============================================================
# 
# INSTRUÇÕES:
# 1. Substituir 'meu-site.pt' pelo seu domínio
# 2. Substituir 127.0.0.1:3000 pela porta do seu servidor Node
# 3. Copiar certificados SSL para /etc/letsencrypt/live/meu-site.pt/
# 4. Linux: sudo ln -s /etc/nginx/sites-available/loja-sende.conf /etc/nginx/sites-enabled/
# 5. sudo nginx -t && sudo systemctl reload nginx
# ============================================================

# ============================================================
# REDIRECIONAMENTO HTTP → HTTPS + WWW
# ============================================================
server {
    listen 80;
    listen [::]:80;
    server_name meu-site.pt www.meu-site.pt;

    # Redirecionar todo HTTP para HTTPS
    return 301 https://meu-site.pt$request_uri;
}

# ============================================================
# REDIRECIONAMENTO WWW → SEM WWW (opcional)
# ============================================================
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.meu-site.pt;

    # Certificados SSL
    ssl_certificate /etc/letsencrypt/live/meu-site.pt/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/meu-site.pt/privkey.pem;

    # Redirecionar www para sem-www
    return 301 https://meu-site.pt$request_uri;
}

# ============================================================
# SERVIDOR PRINCIPAL - HTTPS
# ============================================================
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name meu-site.pt;

    # ============================================================
    # CERTIFICADOS SSL/TLS - Let's Encrypt
    # ============================================================
    ssl_certificate /etc/letsencrypt/live/meu-site.pt/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/meu-site.pt/privkey.pem;

    # ============================================================
    # CONFIGURAÇÕES SSL DE SEGURANÇA
    # ============================================================
    # Usar TLS moderno
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers on;

    # Session SSL
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    # HSTS - Força HTTPS durante 1 ano
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # Outras headers de segurança
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ============================================================
    # CONFIGURAÇÕES GERAIS
    # ============================================================
    root /var/www/loja-sende;
    index index.html index.htm;

    # Logging
    access_log /var/log/nginx/loja-sende.access.log combined;
    error_log /var/log/nginx/loja-sende.error.log;

    # Compressão
    gzip on;
    gzip_vary on;
    gzip_min_length 1000;
    gzip_types text/plain text/css text/xml text/javascript application/x-javascript application/xml+rss application/json;

    # Limite de upload
    client_max_body_size 50M;

    # Timeouts
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # ============================================================
    # PROXY REVERSO - Node.js Backend
    # ============================================================
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;

        # Headers importantes
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;

        # Evitar cache
        proxy_cache_bypass $http_upgrade;
        proxy_no_cache $http_upgrade;

        # Buffers
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;
    }

    # ============================================================
    # WEBSOCKETS (se necessário)
    # ============================================================
    location /ws {
        proxy_pass http://127.0.0.1:3000/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400;
    }

    # ============================================================
    # CACHE ESTÁTICO - Imagens, CSS, JS
    # ============================================================
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        proxy_pass http://127.0.0.1:3000;
        expires 7d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # ============================================================
    # VERIFICAÇÃO DE SAÚDE
    # ============================================================
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    # ============================================================
    # NEGAR ACESSO A FICHEIROS SENSÍVEIS
    # ============================================================
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location ~ ~$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # ============================================================
    # RATE LIMITING (opcional)
    # ============================================================
    limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;
    limit_req_zone $binary_remote_addr zone=login_limit:10m rate=5r/m;

    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;
        proxy_pass http://127.0.0.1:3000;
        # ... resto do proxy config
    }

    location /api/users/login {
        limit_req zone=login_limit burst=3 nodelay;
        proxy_pass http://127.0.0.1:3000;
        # ... resto do proxy config
    }
}

# ============================================================
# UPSTREAM (opcional - para load balancing)
# ============================================================
# upstream backend {
#     server 127.0.0.1:3000 weight=1;
#     server 127.0.0.1:3001 weight=1;
#     keepalive 64;
# }
#
# location / {
#     proxy_pass http://backend;
# }
